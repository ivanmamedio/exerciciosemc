{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "C/C++: gcc compilar e depurar arquivo ativo",
            "type": "cppdbg",
            "request": "launch",
            "program": "${fileDirname}/${fileBasenameNoExtension}",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Habilitar a reformatação bonita para o gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Compilar arquivo ativo com gcc",
            "miDebuggerPath": "/usr/bin/gdb"
        }
    ]
}